; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="2d_Horror"
run/main_scene="res://rooms/node_2d.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://icon.svg"

[autoload]

G="*res://script/global.gd"
TemplateData="*res://addons/TemplateSaver/Code/TemplateData.gd"
Dialog="*res://addons/TemplateSaver/Code/Dialog.gd"
scene_manager="*res://scene_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
SignalBus="*res://dialogue/signal_bus.gd"

[dialogue_manager]

general/states=["scene_manager"]

[display]

window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/TemplateSaver/plugin.cfg", "res://addons/dialogue_manager/plugin.cfg", "res://addons/godotgpt/plugin.cfg")

[importer_defaults]

animation_library={
"animation/fps": 60.0
}

