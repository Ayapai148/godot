[sub_resource type="GDScript" id="GDScript_rvbbo"]
script/source = "extends Label


# Called when the node enters the scene tree for the first time.
func _ready():
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta):
	text = \"жизнь:\" + str($\"../../Node2D/Player\".health)
"

[sub_resource type="GDScript" id="GDScript_k2j1l"]
script/source = "extends Node2D

var money = preload(\"res://монета.tscn\")


func _on_timer_timeout():
	var moneyTemp = money.instantiate()
	var rnd = RandomNumberGenerator.new()
	var randint = randi_range(50, 1200)
	moneyTemp.position = Vector2 (randint,635)
	add_child(moneyTemp)

	
"

